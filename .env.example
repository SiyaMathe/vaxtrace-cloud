# Local SQL Server (Docker)
SqlConnectionString="Server=localhost,1433;Database=VaxTraceDB;User Id=sa;Password=VaxTrace_Dev123!;TrustServerCertificate=True;"

# Azurite local storage emulator
VaxTraceStorage="UseDevelopmentStorage=true"
VaccinationQueueName="vaccination-queue"
VaccinationBlobContainer="vaccination-raw-archive"
ProcessedBlobContainer="vaccination-processed"

# Azure (fill in when you have credits)
# VaxTraceStorage="DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>"
# SqlConnectionString="Server=<server>.database.windows.net;Database=VaxTraceDB;User Id=sqladmin;Password=<pwd>;Encrypt=True;"

# Application Insights (optional locally)
APPLICATIONINSIGHTS_CONNECTION_STRING=""
